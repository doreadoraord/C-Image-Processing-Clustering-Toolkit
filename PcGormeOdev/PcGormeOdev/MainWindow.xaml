<Window x:Class="PcGormeOdev.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Görüntü İşleme Projesi (Zoom ve Pan Özellikli)" Height="760" Width="1300" WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="220"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="SolCerceve" Grid.Column="0" BorderBrush="Black" BorderThickness="1" Margin="2" Background="#EEE" ClipToBounds="True"
                    MouseWheel="ImgSol_MouseWheel" MouseLeftButtonDown="ImgSol_MouseDown" MouseLeftButtonUp="ImgSol_MouseUp" MouseMove="ImgSol_MouseMove">
                <Grid>
                    <Image x:Name="OriginalImage" Stretch="Fill" RenderTransformOrigin="0,0">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SolOlcek"/>
                                <TranslateTransform x:Name="SolKaydirma"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock Text="Orijinal (Zoom: Tekerlek, Pan: Sürükle)" VerticalAlignment="Top" HorizontalAlignment="Left" 
                               Background="#80FFFFFF" Padding="5" IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <StackPanel Grid.Column="1" Margin="5">
                <GroupBox Header="Kontrol Paneli" Padding="5">
                    <StackPanel>
                        <Button Content="Resim Yükle" Height="30" Click="LoadImageButton_Click" Margin="0,0,0,5"/>
                        <ComboBox x:Name="OperationComboBox" Margin="0,5" SelectedIndex="0"/>
                        <Grid Margin="0,5">
                            <TextBlock Text="Küme Sayısı (K):" VerticalAlignment="Center"/>
                            <ComboBox x:Name="KValueComboBox" HorizontalAlignment="Right" Width="100" SelectedIndex="2">
                                <ComboBoxItem Content="1"/>
                                <ComboBoxItem Content="2"/>
                                <ComboBoxItem Content="3"/>
                                <ComboBoxItem Content="4"/>
                                <ComboBoxItem Content="5"/>
                                <ComboBoxItem Content="6"/>
                                <ComboBoxItem Content="7"/>
                                <ComboBoxItem Content="8"/>
                                <ComboBoxItem Content="9"/>
                                <ComboBoxItem Content="10"/>
                                <ComboBoxItem Content="12"/>
                                <ComboBoxItem Content="14"/>
                                <ComboBoxItem Content="16"/>
                                <ComboBoxItem Content="18"/>
                                <ComboBoxItem Content="20"/>
                                <ComboBoxItem Content="25"/>
                                <ComboBoxItem Content="30"/>
                                <ComboBoxItem Content="35"/>
                                <ComboBoxItem Content="40"/>
                                <ComboBoxItem Content="45"/>
                                <ComboBoxItem Content="50"/>
                            </ComboBox>
                        </Grid>
                        <Button x:Name="ProcessButton" Content="Uygula" Height="40" FontWeight="Bold" Click="ProcessButton_Click" Margin="0,10,0,0"/>
                    </StackPanel>
                </GroupBox>

                <TextBlock Text="Histogram (Zoom: Tekerlek, Pan: Sürükle)" Margin="0,10,0,0" FontSize="10" Foreground="Gray"/>
                <Border BorderBrush="Black" BorderThickness="1" Height="250" Background="White" ClipToBounds="True"
                        MouseWheel="Hist_MouseWheel" MouseLeftButtonDown="Hist_MouseDown" MouseLeftButtonUp="Hist_MouseUp" MouseMove="Hist_MouseMove">
                    <Canvas x:Name="HistogramCanvas">
                        <Canvas.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="HistScale"/>
                                <TranslateTransform x:Name="HistTranslate"/>
                            </TransformGroup>
                        </Canvas.RenderTransform>
                    </Canvas>
                </Border>

                <Border BorderBrush="Gray" BorderThickness="1" Margin="0,10,0,0" Padding="5" Background="#F0F0F0">
                    <StackPanel>
                        <TextBlock Text="Mouse Bilgisi (Pixel RGB):" FontWeight="Bold"/>
                        <TextBlock x:Name="MouseInfoText" Text="X: 0, Y: 0 | R:0 G:0 B:0" TextWrapping="Wrap" FontWeight="Bold" FontSize="14"/>
                        <TextBlock x:Name="SelectedPixelInfo" Text="Seçilen: -" Foreground="DarkRed" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border x:Name="SagCerceve" Grid.Column="2" BorderBrush="Black" BorderThickness="1" Margin="2" Background="#EEE" ClipToBounds="True"
                    MouseWheel="ImgSag_MouseWheel" MouseLeftButtonDown="ImgSag_MouseDown" MouseLeftButtonUp="ImgSag_MouseUp" MouseMove="ImgSag_MouseMove">
                <Grid>
                    <Image x:Name="ProcessedImage" Stretch="Fill" RenderTransformOrigin="0,0">
                        <Image.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform x:Name="SagOlcek"/>
                                <TranslateTransform x:Name="SagKaydirma"/>
                            </TransformGroup>
                        </Image.RenderTransform>
                    </Image>
                    <TextBlock Text="İşlenmiş (Zoom: Tekerlek, Pan: Sürükle)" VerticalAlignment="Top" HorizontalAlignment="Left" 
                               Background="#80FFFFFF" Padding="5" IsHitTestVisible="False"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="1" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Grid.Column="0" Header="Başlangıç Değerleri">
                <ListBox x:Name="StartValuesList"/>
            </GroupBox>

            <StackPanel Grid.Column="1" Width="200" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Toplam Piksel:" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TotalPixelText" Text="0" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="İterasyon:" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock x:Name="IterationText" Text="0" HorizontalAlignment="Center" FontSize="16" Foreground="Blue"/>
            </StackPanel>

            <GroupBox Grid.Column="2" Header="Sonuç Değerleri (Sıralı)">
                <ListView x:Name="ResultListView">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Piksel Sayısı" Width="80" DisplayMemberBinding="{Binding PikselSayisi}"/>
                            <GridViewColumn Header="T (R)" Width="60" DisplayMemberBinding="{Binding Kirmizi}"/>
                            <GridViewColumn Header="T (G)" Width="60" DisplayMemberBinding="{Binding Yesil}"/>
                            <GridViewColumn Header="T (B)" Width="60" DisplayMemberBinding="{Binding Mavi}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </GroupBox>
        </Grid>
    </Grid>
</Window>